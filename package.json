{
  "name": "birthday-planner",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev -w birthday-planner-frontend",
    "dev:backend": "npm run dev -w birthday-planner-backend",
    "dev:all": "npm run build -w birthday-planner-frontend && npm run dev -w birthday-planner-backend",
    "build": "npm run build -w birthday-planner-frontend",
    "build:backend": "npm run build -w birthday-planner-frontend",
    "lint": "npm run lint -w birthday-planner-frontend",
    "preview": "npm run preview -w birthday-planner-frontend",
    "db:migrate:local": "npm run db:migrate:local -w birthday-planner-backend",
    "db:migrate:remote": "npm run db:migrate:remote -w birthday-planner-backend",
    "deploy": "npm run build -w birthday-planner-frontend && npm run deploy -w birthday-planner-backend",
    "deploy:cloudflare": "wrangler deploy --config backend/wrangler.toml"
  }
}
